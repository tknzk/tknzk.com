%div.page-wrapper
  %header.site-header
    %nav.site-nav{'aria-label': 'Main navigation'}
      %a.nav-logo{href: '/'}
        tknzk
      %div.nav-links
        %a.nav-link{href: '#products'} Products
        %a.nav-link{href: '#oss'} OSS
        %a.nav-link{href: 'https://tknzk.hateblo.jp/', target: '_blank', rel: 'noopener noreferrer'}
          Blog
          %span.sr-only (opens in new tab)
        %a.nav-link{href: 'https://github.com/tknzk/CV', target: '_blank', rel: 'noopener noreferrer'}
          CV
          %span.sr-only (opens in new tab)
      %button.theme-toggle{'aria-label': 'Toggle theme', type: 'button'}
        %svg.icon-sun{xmlns: 'http://www.w3.org/2000/svg', width: '16', height: '16', viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', 'stroke-width': '2', 'stroke-linecap': 'round', 'stroke-linejoin': 'round'}
          %circle{cx: '12', cy: '12', r: '5'}
          %line{x1: '12', y1: '1', x2: '12', y2: '3'}
          %line{x1: '12', y1: '21', x2: '12', y2: '23'}
          %line{x1: '4.22', y1: '4.22', x2: '5.64', y2: '5.64'}
          %line{x1: '18.36', y1: '18.36', x2: '19.78', y2: '19.78'}
          %line{x1: '1', y1: '12', x2: '3', y2: '12'}
          %line{x1: '21', y1: '12', x2: '23', y2: '12'}
          %line{x1: '4.22', y1: '19.78', x2: '5.64', y2: '18.36'}
          %line{x1: '18.36', y1: '5.64', x2: '19.78', y2: '4.22'}
        %svg.icon-moon{xmlns: 'http://www.w3.org/2000/svg', width: '16', height: '16', viewBox: '0 0 24 24', fill: 'none', stroke: 'currentColor', 'stroke-width': '2', 'stroke-linecap': 'round', 'stroke-linejoin': 'round'}
          %path{d: 'M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z'}

  %main
    %section.hero{'aria-label': 'Introduction'}
      %div.hero-content
        %p.hero-tag.anim-reveal Indie Hacker & Software Engineer
        %h1.hero-title
          %span.hero-line.anim-reveal Build.
          %span.hero-line.anim-reveal Ship.
          %span.hero-line.hero-line--accent.anim-reveal Repeat.
        %p.hero-desc.anim-reveal
          I craft tools, APIs, and apps that solve real problems.
          Shipping fast, iterating often, and building in public.
        %div.hero-actions.anim-reveal
          %a.btn-primary{href: '#products'} See what I've built
          %a.btn-ghost{href: 'https://www.github.com/tknzk', target: '_blank', rel: 'noopener noreferrer'}
            %i.fa-brands.fa-github{'aria-hidden': 'true'}
            GitHub
            %span.sr-only (opens in new tab)

    %section#products.products{'aria-labelledby': 'products-heading'}
      %div.section-inner
        %div.section-header.anim-fade
          %span.section-number{'aria-hidden': 'true'} 01
          %h2#products-heading Products
          %p.section-subtitle Things I've shipped

        %div.product-grid
          - @products.each do |p|
            %a.product-card.anim-fade{href: p[:url], target: '_blank', rel: 'noopener noreferrer'}
              %div.product-card-header
                %span.product-tag= p[:tag]
                %span.product-arrow{'aria-hidden': 'true'} &nearr;
              %h3.product-title= p[:title]
              %p.product-desc= p[:desc]
              %span.sr-only (opens in new tab)

    %section#oss.oss{'aria-labelledby': 'oss-heading'}
      %div.section-inner
        %div.section-header.anim-fade
          %span.section-number{'aria-hidden': 'true'} 02
          %h2#oss-heading Open Source
          %p.section-subtitle Libraries & contributions

        %div.oss-list.anim-fade
          - @libraries.each_with_index do |l, i|
            %a.oss-item{href: l[:url], target: '_blank', rel: 'noopener noreferrer'}
              %span.oss-index{'aria-hidden': 'true'}= format('%02d', i + 1)
              %span.oss-title= l[:title]
              %span.oss-arrow{'aria-hidden': 'true'} &rarr;
              %span.sr-only (opens in new tab)

    %section.about{'aria-labelledby': 'about-heading'}
      %div.section-inner
        %div.section-header.anim-fade
          %span.section-number{'aria-hidden': 'true'} 03
          %h2#about-heading About
          %p.section-subtitle Connect & follow

        %div.about-content.anim-fade
          %p.about-text
            Software engineer who loves building useful things.
            From APIs to apps, I enjoy the full cycle of shipping products.

          %div.connect-grid
            %a.connect-card{href: 'https://www.github.com/tknzk', target: '_blank', rel: 'noopener noreferrer'}
              %i.fa-brands.fa-github{'aria-hidden': 'true'}
              %span GitHub
              %span.sr-only (opens in new tab)
            %a.connect-card{href: 'https://www.twitter.com/tknzk', target: '_blank', rel: 'noopener noreferrer'}
              %i.fa-brands.fa-x-twitter{'aria-hidden': 'true'}
              %span X
              %span.sr-only (opens in new tab)
            %a.connect-card{href: 'https://speakerdeck.com/tknzk', target: '_blank', rel: 'noopener noreferrer'}
              %i.fa-brands.fa-speaker-deck{'aria-hidden': 'true'}
              %span Talks
              %span.sr-only (opens in new tab)
            %a.connect-card{href: 'https://tknzk.hatenablog.jp/', target: '_blank', rel: 'noopener noreferrer'}
              %i.fa-regular.fa-pen-to-square{'aria-hidden': 'true'}
              %span Blog
              %span.sr-only (opens in new tab)

          %div.contact-info
            %div.contact-item
              %i.fa-regular.fa-envelope{'aria-hidden': 'true'}
              %span i&#110;fo&#64;t&#107;n&#122;k&#46;&#99;&#111;&#109;

  %footer.site-footer
    %div.footer-content
      %span.footer-text &copy; 2025 tknzk
      %span.footer-dot{'aria-hidden': 'true'} &middot;
      %span.footer-text Always shipping

:javascript
  document.addEventListener('DOMContentLoaded', function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.anim-reveal, .anim-fade').forEach(function(el) {
      observer.observe(el);
    });

    var toggle = document.querySelector('.theme-toggle');
    if (toggle) {
      toggle.addEventListener('click', function() {
        var current = document.documentElement.getAttribute('data-theme');
        var next = current === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
      });
    }
  });
