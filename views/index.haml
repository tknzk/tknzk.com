%div.page-wrapper
  %header.site-header
    %nav.site-nav{'aria-label': 'Main navigation'}
      %a.nav-logo{href: '/'}
        tknzk
      %div.nav-links
        %a.nav-link{href: 'https://tknzk.hatenablog.jp/', target: '_blank', rel: 'noopener noreferrer'}
          Blog
          %span.sr-only (opens in new tab)
        %a.nav-link{href: 'https://tknzk.hateblo.jp/', target: '_blank', rel: 'noopener noreferrer'}
          Tech
          %span.sr-only (opens in new tab)
        %a.nav-link{href: 'https://www.tknzk.app/', target: '_blank', rel: 'noopener noreferrer'}
          Apps
          %span.sr-only (opens in new tab)
        %a.nav-link{href: 'https://github.com/tknzk/CV', target: '_blank', rel: 'noopener noreferrer'}
          CV
          %span.sr-only (opens in new tab)

  %main
    %section.hero{'aria-label': 'Introduction'}
      %div.hero-content
        %h1.hero-title
          %span.hero-line.anim-reveal Takumi
          %span.hero-line.anim-reveal Kanzaki
        %p.hero-subtitle.anim-reveal
          Software Engineer
        %div.hero-accent{'aria-hidden': 'true'}

    %section.about{'aria-labelledby': 'about-heading'}
      %div.section-grid
        %div.section-label.anim-fade
          %span.label-number{'aria-hidden': 'true'} 01
          %h2.label-text#about-heading About

        %div.section-content.anim-fade
          %p.about-text
            Building software with intention and craft.
          %div.contact-info
            %div.contact-item
              %i.fa-regular.fa-envelope{'aria-hidden': 'true'}
              %span i&#110;fo&#64;t&#107;n&#122;k&#46;&#99;&#111;&#109;

          %div.social-links
            %a.social-link{href: 'https://www.github.com/tknzk', target: '_blank', rel: 'noopener noreferrer'}
              %i.fa-brands.fa-square-github{'aria-hidden': 'true'}
              %span GitHub
              %span.sr-only (opens in new tab)
            %a.social-link{href: 'https://www.twitter.com/tknzk', target: '_blank', rel: 'noopener noreferrer'}
              %i.fa-brands.fa-x-twitter{'aria-hidden': 'true'}
              %span X
              %span.sr-only (opens in new tab)
            %a.social-link{href: 'https://www.facebook.com/tknzk', target: '_blank', rel: 'noopener noreferrer'}
              %i.fa-brands.fa-square-facebook{'aria-hidden': 'true'}
              %span Facebook
              %span.sr-only (opens in new tab)
            %a.social-link{href: 'https://speakerdeck.com/tknzk', target: '_blank', rel: 'noopener noreferrer'}
              %i.fa-brands.fa-speaker-deck{'aria-hidden': 'true'}
              %span Talks
              %span.sr-only (opens in new tab)

    %section.libraries{'aria-labelledby': 'libraries-heading'}
      %div.section-grid
        %div.section-label.anim-fade
          %span.label-number{'aria-hidden': 'true'} 02
          %h2.label-text#libraries-heading Libraries

        %div.section-content.anim-fade
          %ul.library-list
            - @libralies.each_with_index do |l, i|
              %li.library-item
                %a.library-link{href: l[:url], target: '_blank', rel: 'noopener noreferrer'}
                  %span.library-index{'aria-hidden': 'true'}= format('%02d', i + 1)
                  %span.library-title= l[:title]
                  %span.library-arrow{'aria-hidden': 'true'} &rarr;
                  %span.sr-only (opens in new tab)

  %footer.site-footer
    %div.footer-content
      %span.footer-text &copy; 2019 tknzk
      %span.footer-dot{'aria-hidden': 'true'} &middot;
      %span.footer-text Built with care

:javascript
  document.addEventListener('DOMContentLoaded', function() {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.anim-reveal, .anim-fade').forEach(function(el) {
      observer.observe(el);
    });
  });
